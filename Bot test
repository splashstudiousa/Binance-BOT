"""
Binance Futures Signal Bot
==========================
A signal-only bot (NO real trading) that fetches live market data from
Binance public API and displays EMA/RSI-based signals on a Flask dashboard.

Requirements:
    pip install flask requests pandas ta flask-cors

Run:
    python app.py
Then open: http://localhost:5000
"""

import time
import threading
import logging
from datetime import datetime

import requests
import pandas as pd
import ta  # Technical Analysis library
from flask import Flask, jsonify, render_template_string
from flask_cors import CORS

# ─────────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────────
SYMBOLS = ["BTCUSDT", "ETHUSDT", "BNBUSDT", "SOLUSDT", "XRPUSDT"]
TIMEFRAMES = ["5m", "15m", "1h"]
KLINE_LIMIT = 100          # Number of candles to fetch per request
UPDATE_INTERVAL = 5        # Seconds between signal refreshes
BINANCE_BASE = "https://fapi.binance.com"  # Futures endpoint (public)

# Risk parameters (percentage-based)
STOP_LOSS_PCT = 0.015      # 1.5% stop loss
TAKE_PROFIT_PCT = 0.03     # 3.0% take profit

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%H:%M:%S"
)
log = logging.getLogger(__name__)

# ─────────────────────────────────────────────
# GLOBAL SIGNAL STORE  (updated by background thread)
# ─────────────────────────────────────────────
signal_store = {}   # { "BTCUSDT": { "5m": {...}, "15m": {...}, ... }, ... }
store_lock = threading.Lock()

# ─────────────────────────────────────────────
# BINANCE DATA FETCHER
# ─────────────────────────────────────────────

def fetch_klines(symbol: str, interval: str, limit: int = KLINE_LIMIT) -> pd.DataFrame:
    """
    Fetch OHLCV candlestick data from Binance Futures public API.
    No API key required.
    Returns a DataFrame with columns: open, high, low, close, volume.
    """
    url = f"{BINANCE_BASE}/fapi/v1/klines"
    params = {"symbol": symbol, "interval": interval, "limit": limit}
    try:
        resp = requests.get(url, params=params, timeout=10)
        resp.raise_for_status()
        raw = resp.json()
    except Exception as e:
        log.error(f"Failed to fetch {symbol} {interval}: {e}")
        return pd.DataFrame()

    df = pd.DataFrame(raw, columns=[
        "open_time", "open", "high", "low", "close", "volume",
        "close_time", "qav", "trades", "tbb", "tbq", "ignore"
    ])
    # Keep only what we need and convert to float
    df = df[["open_time", "open", "high", "low", "close", "volume"]].copy()
    for col in ["open", "high", "low", "close", "volume"]:
        df[col] = df[col].astype(float)
    df["open_time"] = pd.to_datetime(df["open_time"], unit="ms")
    return df


# ─────────────────────────────────────────────
# TECHNICAL INDICATORS
# ─────────────────────────────────────────────

def compute_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """
    Add EMA-9, EMA-21, and RSI-14 columns to the DataFrame.
    Uses the `ta` library for reliable calculations.
    """
    if df.empty or len(df) < 22:
        return df

    close = df["close"]

    # Exponential Moving Averages
    df["ema9"]  = ta.trend.EMAIndicator(close, window=9).ema_indicator()
    df["ema21"] = ta.trend.EMAIndicator(close, window=21).ema_indicator()

    # Relative Strength Index
    df["rsi"] = ta.momentum.RSIIndicator(close, window=14).rsi()

    return df


# ─────────────────────────────────────────────
# SIGNAL ENGINE
# ─────────────────────────────────────────────

def generate_signal(df: pd.DataFrame, symbol: str, timeframe: str) -> dict:
    """
    Core signal logic:
      LONG  → EMA9 > EMA21  AND  RSI < 65  AND  RSI > 40
      SHORT → EMA9 < EMA21  AND  RSI > 35  AND  RSI < 60
      HOLD  → anything else (conflicting signals)

    Confidence is calculated from:
      - EMA spread (how far apart the two EMAs are, as % of price)
      - RSI distance from neutral zone (50)
    """
    if df.empty or len(df) < 22:
        return _empty_signal(symbol, timeframe, "Insufficient data")

    df = compute_indicators(df)
    if df["ema9"].isna().all():
        return _empty_signal(symbol, timeframe, "Indicator error")

    # Use the latest completed candle (second-to-last row avoids partial candle)
    latest = df.iloc[-2]
    price   = round(latest["close"], 4)
    ema9    = latest["ema9"]
    ema21   = latest["ema21"]
    rsi     = round(latest["rsi"], 2)

    if pd.isna(ema9) or pd.isna(ema21) or pd.isna(rsi):
        return _empty_signal(symbol, timeframe, "Indicator NaN")

    # ── Signal Decision ──────────────────────
    ema_bull = ema9 > ema21   # Bullish crossover
    ema_bear = ema9 < ema21   # Bearish crossover
    ema_spread_pct = abs(ema9 - ema21) / price * 100  # Strength of EMA divergence

    if ema_bull and 40 <= rsi <= 65:
        signal = "LONG"
    elif ema_bear and 35 <= rsi <= 60:
        signal = "SHORT"
    else:
        signal = "HOLD"

    # ── Confidence Score (0–100) ─────────────
    # Based on EMA spread (capped at 2%) + RSI divergence from 50
    ema_score = min(ema_spread_pct / 2.0, 1.0) * 50   # up to 50 pts
    rsi_score = min(abs(rsi - 50) / 30.0, 1.0) * 50   # up to 50 pts
    confidence = round(ema_score + rsi_score, 1)

    # For HOLD, reduce confidence
    if signal == "HOLD":
        confidence = round(confidence * 0.4, 1)

    # ── Risk Parameters ──────────────────────
    if signal == "LONG":
        stop_loss   = round(price * (1 - STOP_LOSS_PCT), 4)
        take_profit = round(price * (1 + TAKE_PROFIT_PCT), 4)
    elif signal == "SHORT":
        stop_loss   = round(price * (1 + STOP_LOSS_PCT), 4)
        take_profit = round(price * (1 - TAKE_PROFIT_PCT), 4)
    else:
        stop_loss   = None
        take_profit = None

    return {
        "symbol":      symbol,
        "timeframe":   timeframe,
        "signal":      signal,
        "price":       price,
        "ema9":        round(ema9, 4),
        "ema21":       round(ema21, 4),
        "rsi":         rsi,
        "stop_loss":   stop_loss,
        "take_profit": take_profit,
        "confidence":  confidence,
        "updated_at":  datetime.utcnow().strftime("%H:%M:%S UTC"),
        "error":       None,
    }


def _empty_signal(symbol, timeframe, reason):
    return {
        "symbol": symbol, "timeframe": timeframe,
        "signal": "N/A", "price": None,
        "ema9": None, "ema21": None, "rsi": None,
        "stop_loss": None, "take_profit": None,
        "confidence": 0, "updated_at": "—", "error": reason,
    }


# ─────────────────────────────────────────────
# BACKGROUND UPDATE THREAD
# ─────────────────────────────────────────────

def update_signals():
    """
    Runs in a background thread. Fetches klines and regenerates
    signals for all symbol/timeframe combinations every UPDATE_INTERVAL seconds.
    """
    while True:
        log.info("🔄 Updating signals...")
        new_store = {}
        for symbol in SYMBOLS:
            new_store[symbol] = {}
            for tf in TIMEFRAMES:
                df = fetch_klines(symbol, tf)
                sig = generate_signal(df, symbol, tf)
                new_store[symbol][tf] = sig
                log.info(
                    f"  {symbol:10s} [{tf:3s}] → {sig['signal']:5s} "
                    f"| Price: {sig['price']} | RSI: {sig['rsi']} "
                    f"| Conf: {sig['confidence']}%"
                )
        with store_lock:
            signal_store.update(new_store)
        time.sleep(UPDATE_INTERVAL)


# ─────────────────────────────────────────────
# FLASK APP
# ─────────────────────────────────────────────
app = Flask(__name__)
CORS(app)

# ── API Endpoint ─────────────────────────────
@app.route("/api/signals")
def api_signals():
    """Returns all current signals as JSON (polled by the frontend)."""
    with store_lock:
        return jsonify(signal_store)


